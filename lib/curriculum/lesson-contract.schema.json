{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://elevateforhumanity.org/schemas/lesson-contract.json",
  "title": "LessonContract",
  "description": "Schema for a curriculum lesson as it flows through the generator → validator → publish pipeline.",
  "type": "object",
  "required": [
    "lesson_slug",
    "lesson_title",
    "lesson_order",
    "module_order",
    "module_title",
    "script_text",
    "summary_text",
    "reflection_prompt",
    "competency_keys",
    "key_terms",
    "duration_minutes",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "lesson_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 120,
      "description": "URL-safe slug, unique within a program. Format: {module-slug}-lesson-{n}"
    },
    "lesson_title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200
    },
    "lesson_order": {
      "type": "integer",
      "minimum": 0
    },
    "module_order": {
      "type": "integer",
      "minimum": 0
    },
    "module_title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "script_text": {
      "type": "string",
      "minLength": 300,
      "description": "Full lesson body. Minimum 300 characters to prevent stub lessons."
    },
    "summary_text": {
      "type": "string",
      "minLength": 50,
      "maxLength": 500,
      "description": "1–3 sentence learner-facing summary."
    },
    "reflection_prompt": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500,
      "description": "Open-ended question for learner reflection at end of lesson."
    },
    "competency_keys": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 },
      "minItems": 1,
      "maxItems": 3,
      "description": "Competency keys this lesson covers. Max 3 — more than 3 triggers stuffing penalty."
    },
    "key_terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "additionalProperties": false,
        "properties": {
          "term": { "type": "string", "minLength": 1 },
          "definition": { "type": "string", "minLength": 10 }
        }
      },
      "description": "Glossary terms for this lesson."
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 5,
      "maximum": 120
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published"]
    },
    "program_id": {
      "type": "string",
      "format": "uuid"
    },
    "course_id": {
      "type": "string",
      "format": "uuid"
    },
    "module_id": {
      "type": "string",
      "format": "uuid"
    },
    "credential_domain_id": {
      "type": "string",
      "format": "uuid"
    }
  }
}
