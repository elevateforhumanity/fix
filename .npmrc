enable-pre-post-scripts=true
# @netlify/plugin-nextjs checks that styled-jsx resolves from the Next.js entry point.
# Hoist only what Next.js needs as peer deps — full public-hoist-pattern[]=* causes
# OOM during deploy by inflating .next/standalone to several GB.
public-hoist-pattern[]=styled-jsx
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
public-hoist-pattern[]=@sentry/*
